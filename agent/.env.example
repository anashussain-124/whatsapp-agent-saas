# Environment Configuration — WhatsApp Agent SaaS
# Copy to .env and fill in values

# ── Meta WhatsApp Cloud API (replaces Twilio) ──
# Get these from developers.facebook.com → Your App → WhatsApp → Getting Started
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=choose_a_random_string_here

# ── OpenRouter (LLM) ──
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── App ──
APP_ENV=development
APP_PORT=8000
APP_URL=https://your-ngrok-url.ngrok.io

# ── Database ──
# SQLite (default, zero-cost):
DATABASE_URL=sqlite:///./data/whatsapp_agent.db
# OR Supabase Postgres (free tier):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Optional overrides ──
# OPENROUTER_MAX_TOKENS=300
# RATE_LIMIT_PER_PHONE_PER_MIN=20
# CONVERSATION_TTL_HOURS=6
